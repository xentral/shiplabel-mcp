# shiplabel-mcp configuration — copy to `.env` and fill in the carrier(s) you use.
#
# Two kinds of variables:
#   SHIPLABEL_<KEY>   -> becomes the lowercase carrier config key <key>
#                        (e.g. SHIPLABEL_DHL_USERNAME -> dhl_username)
#   DHL_API_CLIENT_*  -> DHL developer-app credentials, read directly (see below)
#
# You never commit `.env`. Set only the carriers you actually ship with.
# Ask a carrier for its API access — every production carrier API needs a
# business account with that carrier. See docs/carriers/<carrier>.md.

# ─────────────────────────────────────────────────────────────────────────────
# DHL Paket (Germany)
# ─────────────────────────────────────────────────────────────────────────────
# 1) Your own developer.dhl.com app credentials (free to register). Sandbox and
#    production are separate apps -> separate variables. Read directly (NOT the
#    SHIPLABEL_ prefix) because they are app-level, not per-shipment.
#DHL_API_CLIENT_ID_SANDBOX=
#DHL_API_CLIENT_SECRET_SANDBOX=
#DHL_API_CLIENT_ID=
#DHL_API_CLIENT_SECRET=
# 2) Your DHL business-customer (GKP) login + billing number.
#    Sandbox: the public DHL test user works out of the box (see docs/carriers/dhl.md).
#SHIPLABEL_DHL_USERNAME=
#SHIPLABEL_DHL_PASSWORD=
#SHIPLABEL_DHL_ACCOUNTNUMBER=
#SHIPLABEL_DHL_SANDBOX=true

# ─────────────────────────────────────────────────────────────────────────────
# DHL Return (Germany)
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_DHL_RETURN_API_KEY=
#SHIPLABEL_DHL_RETURN_USERNAME=
#SHIPLABEL_DHL_RETURN_PASSWORD=
#SHIPLABEL_DHL_RETURN_RECEIVER_ID=
#SHIPLABEL_DHL_RETURN_SANDBOX=true

# ─────────────────────────────────────────────────────────────────────────────
# DPD
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_DPD_PARTNER_NAME=
#SHIPLABEL_DPD_PARTNER_TOKEN=
#SHIPLABEL_DPD_CLOUD_USER_ID=
#SHIPLABEL_DPD_USER_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# UPS
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_UPS_CLIENT_ID=
#SHIPLABEL_UPS_CLIENT_SECRET=
#SHIPLABEL_UPS_ACCOUNT_NUMBER=
#SHIPLABEL_UPS_SANDBOX=true

# ─────────────────────────────────────────────────────────────────────────────
# FedEx
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_FEDEX_CLIENT_ID=
#SHIPLABEL_FEDEX_CLIENT_SECRET=
#SHIPLABEL_FEDEX_ACCOUNT_NUMBER=
#SHIPLABEL_FEDEX_SERVICE=
#SHIPLABEL_FEDEX_SANDBOX=true

# ─────────────────────────────────────────────────────────────────────────────
# GLS
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_GLS_USERNAME=
#SHIPLABEL_GLS_PASSWORD=
#SHIPLABEL_GLS_CUSTOMER_ID=
#SHIPLABEL_GLS_CONTACT_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Sendcloud (multi-carrier aggregator: PostNL, Swiss Post, Österr. Post, DPD, DHL…)
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_SENDCLOUD_PUBLIC_KEY=
#SHIPLABEL_SENDCLOUD_SECRET_KEY=
#SHIPLABEL_SENDCLOUD_METHOD_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Shipcloud (aggregator)
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_SHIPCLOUD_API_KEY=
#SHIPLABEL_SHIPCLOUD_CARRIER=
#SHIPLABEL_SHIPCLOUD_AFFILIATE_ID=

# ─────────────────────────────────────────────────────────────────────────────
# Optional: add or override carriers without forking — a directory of *.json specs.
# ─────────────────────────────────────────────────────────────────────────────
#SHIPLABEL_CARRIERS_DIR=/path/to/extra/carrier/specs
